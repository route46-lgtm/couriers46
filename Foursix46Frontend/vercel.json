{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://europe-west2-foursix46-production-4a43f.cloudfunctions.net/api/sitemap.xml"
    },


    {
      "source": "/admin/(.*)",
      "destination": "/index.html"
    },

    {
      "source": "/((?!admin|api/|assets/|.*\\..*).*)",
      "destination": "/$1.html"
    }
  ]
}